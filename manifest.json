{
  "manifest_version": 3,
  "name": "Volume Control",
  "version": "6",
  "description": "Adds a volume control for the current site, that can also boost the volume beyond the normal range.",
  "homepage_url": "https://github.com/Chaython/volumecontrol",
  "icons": {
    "96": "chrome.png"
  },
  "permissions": [
    "storage",
    "activeTab"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "action": {
    "default_icon": "chrome.png",
    "default_title": "Volume Control",
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": [
        "http://*/*",
        "https://*/*",
        "file:///*"
      ],
      "js": [
        "page-audio-hook.js"
      ],
      "run_at": "document_start",
      "all_frames": true,
      "match_about_blank": true,
      "match_origin_as_fallback": true,
      "world": "MAIN"
    },
    {
      "matches": [
        "http://*/*",
        "https://*/*",
        "file:///*"
      ],
      "js": [
        "lib/arrive.min.js",
        "cs.js"
      ],
      "run_at": "document_start",
      "all_frames": true,
      "match_about_blank": true,
      "match_origin_as_fallback": true
    }
  ],
  "options_ui": {
    "page": "options.html",
    "open_in_tab": true
  },
  "commands": {
    "_execute_action": {
      "description": "Open volume control"
    }
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "{57e8684d-5ae8-47d6-93c9-f870ef0e40a3}",
      "data_collection_permissions": {
        "required": [
          "none"
        ]
      },
      "strict_min_version": "128.0"
    }
  }
}
